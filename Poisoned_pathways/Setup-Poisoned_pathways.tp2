/*
 COPY ~Poisoned_pathways/bam/bam_desc_BG2EE/DAC#MITH.bam~ ~override~ // Mithril desc bam
 LPF UPDATE_PVRZ_INDICES RET original_base_index new_base_index END 
 ACTION_IF (original_base_index >= 0 AND new_base_index >= 0) BEGIN 
 LAF INSTALL_PVRZ INT_VAR original_base_index new_base_index STR_VAR source_file = ~Poisoned_pathways/bam/bam_desc_BG2EE/MOS1001.pvrz~
 END
 END
*/

