USING ~Poisoned_pathways/language/%LANGUAGE%/Poisoned_pathways_Journal.tra~

///////////////////////////////////////////////////////////////////////
// Patching IDS files
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/patches.tpa~

///////////////////////////////////////////////////////////////////////
// Animations
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/Poisoned_pathways-animations.tpa~

///////////////////////////////////////////////////////////////////////
// 2DA files
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/Poisoned_pathways-2da.tpa~

// appending Entries for LeaveAreaLUAEntry working correctly 
APPEND ~ENTRIES.2DA~
~ACPP73		1965.1990   1236.1311           *          *         *         *         *         *        *~
UNLESS ~ACPP73~

APPEND ~splprot.2da~ ~AC#FOREST_AREA%TAB%0x106%TAB%0x0010%TAB%8~ UNLESS ~AC#FOREST_AREA~

COPY_EXISTING ~splprot.2da~ ~override~
   COUNT_2DA_COLS cols // amount of columns
   READ_2DA_ENTRIES_NOW rows cols // read all file into memory  
   FOR (row = 1; row < rows; ++row) BEGIN // iterate over rows
      READ_2DA_ENTRY_FORMER rows row 0 ~stat~ // read column value
      PATCH_IF ~%stat%~ STRING_EQUAL_CASE ~AC#FOREST_AREA~ BEGIN
         SET forest_row = %row%
      END
   END
BUT_ONLY

///////////////////////////////////////////////////////////////////////
// ARE files
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/Poisoned_pathways-areas.tpa~

