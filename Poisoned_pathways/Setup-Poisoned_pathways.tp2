COPY ~Poisoned_pathways/spl/copy~         ~override~

// copy spell and make forest area work:
COPY ~Poisoned_pathways/spl/AC#PPRF.spl~ ~override~
  LPF ALTER_EFFECT INT_VAR
    match_opcode = 326
    parameter2 = %forest_row%
  END

COPY ~Poisoned_pathways/spl/AC#PPPE.spl~          ~override~
SAY NAME1 @913

COPY ~Poisoned_pathways/spl/AC#PP43.spl~          ~override~
SAY NAME1 @912

