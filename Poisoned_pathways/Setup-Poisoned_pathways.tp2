
BACKUP ~Poisoned_pathways/backup~
AUTHOR ~Acifer~
//README ~Poisoned_pathways/readme.Poisoned_pathways.%LANGUAGE%.html~ ~readme.Poisoned_pathways.english.html~
VERSION ~BETA5.1~

ALWAYS

  ACTION_IF GAME_IS ~eet~ BEGIN
    OUTER_SET bg2_chapter = 12
  END ELSE BEGIN
    OUTER_SET bg2_chapter = 0
  END
  OUTER_FOR (i=1; i<=10; i=i+1) BEGIN
    OUTER_SET bg2_chapter = bg2_chapter + 1
    OUTER_TEXT_SPRINT name_source ~bg2_chapter_%i%~
    OUTER_SET EVAL ~%name_source%~ = bg2_chapter
  END


  //either use cpmvars that have these variables set or add this variable declaration somewhere in your tp2 code
  ACTION_IF GAME_IS ~eet~ BEGIN
    OUTER_SET wmp_xCoord_SoA = 0 //in relation to BG2/BG2:EE WORLDMAP.WMP add 0 px correction to X coordinate
    OUTER_SET wmp_yCoord_SoA = 2283 //in relation to BG2/BG2:EE WORLDMAP.WMP add 2283 px correction to Y coordinate
    OUTER_TEXT_SPRINT wmp_worldmap_ToB "worldmap" //when editing ToB worldmap use WORLDMAP.WMP instead of WORLDM25.WMP
  END ELSE BEGIN
    OUTER_SET wmp_xCoord_SoA = 0
    OUTER_SET wmp_yCoord_SoA = 0
    OUTER_TEXT_SPRINT wmp_worldmap_ToB "worldm25"
  END
END
///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////
//
///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////

AUTO_TRA ~Poisoned_pathways/language/%s~

LANGUAGE ~English~
         ~english~
         ~Poisoned_pathways/language/english/Setup-Poisoned_pathways.tra~
         ~Poisoned_pathways/language/english/Poisoned_pathways_Journal.tra~

BEGIN ~Poisoned pathways~

REQUIRE_PREDICATE (GAME_IS ~bg2ee eet~ && FILE_EXISTS ~engine.lua~) ~Requires BG2:EE or EET patched to 2.0 or higher.~

INCLUDE ~Poisoned_pathways/lib/extra_regexp_vars.tph~
INCLUDE ~Poisoned_pathways/lib/functions.tph~

//ADD_JOURNAL  USING ~Poisoned_pathways/language/%LANGUAGE%/Poisoned_pathways_Journal.tra~

///////////////////////////////////////////////////////////////////////
// Patching IDS files
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/patches.tpa~

///////////////////////////////////////////////////////////////////////
// Animations
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/Poisoned_pathways-animations.tpa~

///////////////////////////////////////////////////////////////////////
// 2DA files
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/Poisoned_pathways-2da.tpa~

// appending Entries for LeaveAreaLUAEntry working correctly 
APPEND ~ENTRIES.2DA~
~ACPP73		1965.1990   1236.1311           *          *         *         *         *         *        *~
UNLESS ~ACPP73~

APPEND ~splprot.2da~ ~AC#FOREST_AREA%TAB%0x106%TAB%0x0010%TAB%8~ UNLESS ~AC#FOREST_AREA~

COPY_EXISTING ~splprot.2da~ ~override~
   COUNT_2DA_COLS cols // amount of columns
   READ_2DA_ENTRIES_NOW rows cols // read all file into memory  
   FOR (row = 1; row < rows; ++row) BEGIN // iterate over rows
      READ_2DA_ENTRY_FORMER rows row 0 ~stat~ // read column value
      PATCH_IF ~%stat%~ STRING_EQUAL_CASE ~AC#FOREST_AREA~ BEGIN
         SET forest_row = %row%
      END
   END
BUT_ONLY

///////////////////////////////////////////////////////////////////////
// ARE files
//
///////////////////////////////////////////////////////////////////////

INCLUDE ~Poisoned_pathways/lib/Poisoned_pathways-areas.tpa~

