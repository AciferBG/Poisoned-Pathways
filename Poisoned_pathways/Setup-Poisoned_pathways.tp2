COPY ~Poisoned_pathways/spl/copy~         ~override~

ADD_PROJECTILE      ~Poisoned_pathways/pro/AC#PPWW.PRO~ // Will-o-wilds wild spray
COPY ~Poisoned_pathways/spl/AC#PPWW.spl~          ~override~  // Will-o-wilds wild spray
SAY NAME1 @914
WRITE_SHORT   0x98 ~%AC#PPWW%~
// face of the forest: copy spell and make forest area work:
COPY ~Poisoned_pathways/spl/AC#PPRF.spl~ ~override~
  LPF ALTER_EFFECT INT_VAR
    match_opcode = 326
    parameter2 = %forest_row%
  END
  
// leafrunner: copy spell and make forest area work:
COPY ~Poisoned_pathways/spl/AC#PPHB.spl~ ~override~
  LPF ALTER_EFFECT INT_VAR
    match_opcode = 326
    parameter2 = %forest_row%
  END

