///////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////

AUTO_TRA ~Poisoned_pathways/language/%s~

LANGUAGE ~English~
         ~english~
         ~Poisoned_pathways/language/english/Setup-Poisoned_pathways.tra~
         ~Poisoned_pathways/language/english/Poisoned_pathways_Journal.tra~

BEGIN ~Poisonous pathways~

REQUIRE_PREDICATE (GAME_IS ~bg2ee eet~ && FILE_EXISTS ~engine.lua~) ~Requires BG2:EE or EET patched to 2.0 or higher.~

INCLUDE ~Poisoned_pathways/lib/extra_regexp_vars.tph~
INCLUDE ~Poisoned_pathways/lib/functions.tph~

//ADD_JOURNAL  USING ~Poisoned_pathways/language/%LANGUAGE%/Poisoned_pathways_Journal.tra~

