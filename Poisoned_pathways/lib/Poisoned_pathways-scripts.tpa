//Script files

// Detect EEex
ACTION_IF FILE_EXISTS_IN_GAME ~EEex_Actionbar.lua~ BEGIN
    // Import Custom EEex Triggers
    ACTION_IF !FILE_EXISTS_IN_GAME ~m_mocast.lua~ BEGIN
      COPY ~%MOD_FOLDER%/lua/m_mocast.lua~ ~override~
      COPY ~%MOD_FOLDER%/lua/m_motar1.lua~ ~override~
      COPY ~%MOD_FOLDER%/lua/m_momove.lua~ ~override~
    END

    // Update Scripts to use EEex Custom Triggers
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#pp77w.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppchs.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#pphez.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppmum.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppnab.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#pprak.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppskd.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppspi.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppta2.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#pptal.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppwiw.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppwod.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppwow.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppytm.tph~
    INCLUDE ~%MOD_FOLDER%/lib/eeex/ac#ppzmt.tph~
END

// Compile all scripts in folder "scripts_compile"
COMPILE ~%MOD_FOLDER%/scripts/scripts_compile~

// Compiling scripts that contain new music
COMPILE ~%MOD_FOLDER%/scripts/ACPP01.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP10.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP11.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP70.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP81.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP82.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP73.baf~  EVAL
COMPILE ~%MOD_FOLDER%/scripts/ACPP90.baf~  EVAL

EXTEND_TOP ~ar0408.bcs~ ~%MOD_FOLDER%/scripts/_ar0408.baf~ // plot start: 2nd encounter of eldathyn cleric in temple of ilmater in the slums
EXTEND_TOP ~ar1000.bcs~ ~%MOD_FOLDER%/scripts/_ar1000.baf~ // plot: Boy and the Aunt
EXTEND_TOP ~ar2000.bcs~ ~%MOD_FOLDER%/scripts/_ar2000.baf~ // Debbie in Trademeet
EXTEND_TOP ~ar0700.bcs~ ~%MOD_FOLDER%/scripts/_ar0700.baf~ // Debbie in Athkatla
EXTEND_TOP ~ar0334.bcs~ ~%MOD_FOLDER%/scripts/_ar0334.baf~ // Cromwell
EXTEND_TOP ~ar0334.bcs~ ~%MOD_FOLDER%/scripts/_AR0334_blade.baf~ // Cromwell - daynight blade

// promise quest
EXTEND_TOP ~ar0500.bcs~ ~%MOD_FOLDER%/scripts/_AR0500.baf~ // create waiting man behind temple of helm
EXTEND_BOTTOM ~ar0900.bcs~ ~%MOD_FOLDER%/scripts/_AR0900.baf~ // create waiting man behind temple of helm

ACTION_IF FILE_EXISTS_IN_GAME ~AC#W01.BCS~ THEN BEGIN
EXTEND_BOTTOM ~AC#W01.bcs~ ~%MOD_FOLDER%/scripts/_AC#W01.baf~ // crossmod: Debbie in Goldspires if "Call of the Lost Goddess" is installed
END

// create Skann Delth poison seller
EXTEND_TOP ~ar0400.bcs~ ~%MOD_FOLDER%/scripts/_AR0400.baf~

// Patch prey script to affect wearer of Eldath's cloak
EXTEND_TOP ~PREY.bcs~ ~%MOD_FOLDER%/scripts/_PREY.baf~

// Patch prey script to affect wearer of Eldath's cloak
EXTEND_TOP ~HUNTER.bcs~ ~%MOD_FOLDER%/scripts/_PREY.baf~

// PLOT START
EXTEND_TOP ~ar0020.bcs~ ~%MOD_FOLDER%/scripts/_plot_start.baf~ // plot start: first encounter of eldathyn cleric
EXTEND_BOTTOM ~ar0300.bcs~ ~%MOD_FOLDER%/scripts/_plot_start.baf~ // plot start: first encounter of eldathyn cleric
