

// Dialogue Banshee in ACPP76
BEGIN ~AC#PPBA1~

CHAIN IF ~Global("AC#PPBansheeHead","GLOBAL",1)~ THEN AC#PPBA1 hello_need_head
@4805
END
IF~~THEN REPLY @4806 EXTERN AC#PPBA1 fight
IF~PartyHasItem("AC#PPHD1")~THEN REPLY @4807 EXTERN AC#PPBA1 have_head
IF~~THEN REPLY @4808 EXTERN AC#PPBA1 bye

CHAIN IF ~NumTimesTalkedTo(0)~ THEN AC#PPBA1 hello_01
@4809
END
IF~~THEN REPLY @4806 EXTERN AC#PPBA1 fight
IF~~THEN REPLY @4810 EXTERN AC#PPBA1 help
IF~~THEN REPLY @4811 EXTERN AC#PPBA1 help
IF~~THEN REPLY @4812 EXTERN AC#PPBA1 bye

CHAIN IF ~True()~ THEN AC#PPBA1 hello_02
@4805
END
IF~~THEN REPLY @4806 EXTERN AC#PPBA1 fight
IF~~THEN REPLY @4813 EXTERN AC#PPBA1 help
IF~PartyHasItem("AC#PPHD1")~THEN REPLY @4807 EXTERN AC#PPBA1 have_head
IF~~THEN REPLY @4808 EXTERN AC#PPBA1 bye

CHAIN IF ~~ THEN AC#PPBA1 help
@4814
END
IF~~THEN REPLY @4815 EXTERN AC#PPBA1 fight
IF~~THEN REPLY @4816 EXTERN AC#PPBA1 eternal_rest
IF~~THEN REPLY @4817 EXTERN AC#PPBA1 bye

CHAIN IF ~~ THEN AC#PPBA1 eternal_rest
@4818
=
@4819
END
IF~~THEN REPLY @4820 EXTERN AC#PPBA1 search_head_bye
IF~PartyHasItem("AC#PPHD1")~THEN REPLY @4821 EXTERN AC#PPBA1 have_head
IF~~THEN REPLY @4822 EXTERN AC#PPBA1 search_head_bye

CHAIN AC#PPBA1 search_head_bye
@4823  
DO ~AddJournalEntry(@13020,QUEST)
SetGlobal("AC#PPBansheeHead","GLOBAL",1)~ EXIT

CHAIN AC#PPBA1 have_head
@4824
DO ~SetGlobal("AC#PPBansheeHead","GLOBAL",10)
CreateVisualEffectObject("SPDEATH3",Myself)
TakePartyItem("AC#PPHD1")
DestroyItem("AC#PPHD1")
AddexperienceParty(400)
AddJournalEntry(@13022,QUEST_DONE)
DropItem("AC#PPCO1",[-1.-1])
DestroySelf()~ EXIT

CHAIN AC#PPBA1 fight
@4825  
DO ~Enemy()~ EXIT

CHAIN AC#PPBA1 bye
@4805  
EXIT

