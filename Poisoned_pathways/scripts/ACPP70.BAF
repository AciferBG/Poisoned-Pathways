IF
	Global("Prep","ACPP70",0)
THEN
RESPONSE #100
	SetMusic(NIGHT,27)
	SetMusic(DAY,%AC#PP70%)
    OpenDoor("DOOR01")
    OpenDoor("DOOR03")  
    ContainerEnable("Roses",FALSE)
    SpawnPtDeactivate("Spawn_gibberlings")
    SpawnPtDeactivate("Spawn_undead_entry")
    SpawnPtDeactivate("Spawn_ankhegs_entry")
    SpawnPtDeactivate("Spawn_spiders01")  
    SpawnPtDeactivate("Spawn_mounds")
    TriggerActivation("Info_no_way_back",FALSE)
    SoundActivate("Portal01",FALSE)
    SoundActivate("Portal02",FALSE)
    TriggerActivation("Trigger_wardstone",FALSE)
	SetGlobal("Prep","ACPP70",1)
	Continue()
END

IF
  !Global("AC#PPFixMagic","GLOBAL",1)
  Global("AC#PP_GoMythal","GLOBAL",1)
  OR(2)
      TimeOfDay(DUSK)
      TimeOfDay(NIGHT)
  !GlobalTimerNotExpired("AC#PP_AntimagicTimer","GLOBAL")
THEN
  RESPONSE #100
      ApplySpellRES("AC#PPDM",Player1) 
      //AddAreaFlag(DEADMAGICZONE)
      SetGlobalTimer("AC#PP_AntimagicTimer","GLOBAL",6)
      Continue()
END

IF
  !Global("AC#PPFixMagic","GLOBAL",1)
  Global("AC#PP_GoMythal","GLOBAL",1)
  OR(2)
      TimeOfDay(MORNING)
      TimeOfDay(DAY)
  !GlobalTimerNotExpired("AC#PP_WildMagicTimer","GLOBAL")
THEN
  RESPONSE #100
      ApplySpellRES("AC#PPWI",Player1)  
      //RemoveAreaFlag(DEADMAGICZONE)
      SetGlobalTimer("AC#PP_WildMagicTimer","GLOBAL",6)
      Continue()
END

