  !Range(SecondNearest([GOODCUTOFF.0.0.DRUID_ALL]),15)
  Range(SecondNearest([GOODCUTOFF.0.0.DRUID_ALL]),50)
  !StateCheck(SecondNearest([GOODCUTOFF.0.0.DRUID_ALL]),STATE_SILENCED)
  !CheckSpellState(SecondNearest([GOODCUTOFF.0.0.DRUID_ALL]),SI_TRANSMUTATION)
