IF
    NumberOfTimesTalkedTo(0)
    See([PC])
THEN
    RESPONSE #100
        Wait(1)
        StartDialogueNoSet([PC])
END

IF
    See(NearestEnemyOf(Myself))
    Global("Prep","LOCALS",0)
THEN
    RESPONSE #100
        ApplySpell(Myself,WIZARD_STONE_SKIN)  // SPWI408.SPL (Stoneskin)
        ApplySpell(Myself,WIZARD_SPELL_TURNING)  // SPWI701.SPL (Spell Turning)
        ApplySpell(Myself,WIZARD_PROTECTION_FROM_ELECTRICITY)  // SPWI512.SPL (Protection From Electricity)
        SetGlobal("Prep","LOCALS",1)
END

IF
    See(NearestEnemyOf(Myself))
    OR(7)
        StateCheck(LastSeenBy(Myself),STATE_HASTED)
        StateCheck(LastSeenBy(Myself),STATE_IMPROVEDINVISIBILITY)
        StateCheck(LastSeenBy(Myself),STATE_BLESS)
        StateCheck(LastSeenBy(Myself),STATE_CHANT)
        StateCheck(LastSeenBy(Myself),STATE_MIRRORIMAGE)
        StateCheck(LastSeenBy(Myself),STATE_BLUR)
        StateCheck(LastSeenBy(Myself),STATE_INVISIBLE)
    Global("PrepDef","LOCALS",0)
    !StateCheck(Myself,STATE_REALLY_DEAD)
THEN
    RESPONSE #70
        ReallyForceSpell(LastSeenBy(Myself),WIZARD_REMOVE_MAGIC)  // SPWI302.SPL (Remove Magic)
        SetGlobal("PrepDef","LOCALS",1)
    RESPONSE #30
        ApplySpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (Mirror Image)
        SetGlobal("PrepDef","LOCALS",1)
END

IF
    See(NearestEnemyOf(Myself))
    StateCheck(Myself,STATE_SILENCED)
    HaveSpell(WIZARD_VOCALIZE)  // SPWI219.SPL (Vocalize)
THEN
    RESPONSE #100
        Spell(Myself,WIZARD_VOCALIZE)  // SPWI219.SPL (Vocalize)
END

IF
    Allegiance(Myself,ENEMY)
    Detect([PC])
    !See(LastSeenBy(Myself))
    HaveSpell(WIZARD_TRUE_SIGHT)  // SPWI609.SPL (True Sight)
THEN
    RESPONSE #100
        Spell(Myself,WIZARD_TRUE_SIGHT)  // SPWI609.SPL (True Sight)
END

IF
    Allegiance(Myself,ENEMY)
    Detect([PC])
    !See(LastSeenBy(Myself))
    !HaveSpell(WIZARD_TRUE_SIGHT)  // SPWI609.SPL (True Sight)
    Delay(10)
THEN
    RESPONSE #100
        ReallyForceSpell(Myself,WIZARD_TRUE_SIGHT)  // SPWI609.SPL (True Sight)
END

IF
    See(NearestEnemyOf(Myself))
    HaveSpell(WIZARD_STONE_SKIN)  // SPWI408.SPL (Stoneskin)
    CheckStatLT(Myself,1,STONESKINS)
    TookDamage()
    Global("Prep2","LOCALS",0)
    !StateCheck(Myself,STATE_REALLY_DEAD)
THEN
    RESPONSE #100
        DisplayString(Myself,40199)  // Chain Contingency—Mirror Image
        ApplySpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (Mirror Image)
        DisplayString(Myself,3302)  // Chain Contingency—Spell Turning
        ApplySpell(Myself,WIZARD_SPELL_TURNING)  // SPWI701.SPL (Spell Turning)
        DisplayString(Myself,40240)  // Chain Contingency—Mislead
        ApplySpell(Myself,WIZARD_MISLEAD)  // SPWI607.SPL (Mislead)
        DisplayString(Myself,29736)  // Contingency—Stoneskin
        ApplySpell(Myself,WIZARD_STONE_SKIN)  // SPWI408.SPL (Stoneskin)
        SetGlobal("Prep2","LOCALS",1)
END

IF
    HasItem("POTN34",Myself)  // Potion of Magic Protection
    OR(2)
        TimeOfDay(MORNING)
        TimeOfDay(DAY)
    CheckStatLT(Myself,100,RESISTMAGIC)
    !GlobalTimerNotExpired("DrankPotionTimer","LOCALS")
    Range(NearestEnemyOf(Myself),30)
THEN
    RESPONSE #100
        SetGlobalTimer("DrankPotionTimer","LOCALS",ONE_ROUND)
        UseItem("POTN34",Myself)  // Potion of Magic Protection
END

IF
    Allegiance(Myself,ENEMY)
    !HasBounceEffects(Myself)
    HaveSpell(WIZARD_SPELL_TURNING)  // SPWI701.SPL (Spell Turning)
THEN
    RESPONSE #100
        Spell(Myself,WIZARD_SPELL_TURNING)  // SPWI701.SPL (Spell Turning)
END

IF
    LevelPartyLT(16)
    HaveSpell(WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (Incendiary Cloud)
THEN
    RESPONSE #100
        Spell(LastSeenBy(Myself),WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (Incendiary Cloud)
END

IF
    See(NearestEnemyOf(Myself))
    HaveSpell(WIZARD_CLOUDKILL)  // SPWI502.SPL (Cloudkill)
    LevelPartyLT(12)
THEN
    RESPONSE #100
        Spell(NearestEnemyOf(Myself),WIZARD_CLOUDKILL)  // SPWI502.SPL (Cloudkill)
