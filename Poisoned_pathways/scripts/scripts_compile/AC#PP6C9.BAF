IF
    True()
THEN
    RESPONSE #100
        CutSceneId("AC#PPWYR")  // The Undying
        MoveViewObject("AC#PPSD3",INSTANT)  // No such index
        CreateCreatureObjectOffset("CUTSPY","AC#PPSD3",[3.3])  // No such index
