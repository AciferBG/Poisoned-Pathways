    See(NearestEnemyOf(Myself))
    HaveSpell(WIZARD_MAZE)  // SPWI813.SPL (Maze)
THEN
    RESPONSE #100
        Spell(NearestEnemyOf(Myself),WIZARD_MAZE)  // SPWI813.SPL (Maze)
