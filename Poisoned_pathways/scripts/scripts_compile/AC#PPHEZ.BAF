/////////////////////////////////////////////////////////////////////
// Allegiance
/////////////////////////////////////////////////////////////////////
IF
  AttackedBy([GOODCUTOFF],DEFAULT)
  !Allegiance(Myself,ENEMY)
THEN
  RESPONSE #100
    Enemy()
END

/////////////////////////////////////////////////////////////////////
// Create Slimes
/////////////////////////////////////////////////////////////////////
IF
  Global("Slime","ACPP71",1)
THEN
  RESPONSE #100
    SetGlobal("Slime","ACPP71",2)
    CreateCreatureEffect("AC#PPJEG","TRGOOYAA",[504.406],SW)  // Green Slime
    CreateCreatureEffect("AC#PPJEG","TRGOOYAA",[186.389],SW)  // Green Slime
    CreateCreatureEffect("AC#PPJEG","TRGOOYAA",[358.468],SW)  // Green Slime
END

/////////////////////////////////////////////////////////////////////
// Make Stronger
/////////////////////////////////////////////////////////////////////
IF
  Global("Stronger","LOCALS",0)
  LevelPartyGT(10)
THEN
  RESPONSE #100
    ApplySpellRES("AC#PPX1",Myself)  // No such index
    ApplySpellRES("AC#PPX1",Myself)  // No such index
    SetGlobal("Stronger","LOCALS",1)
END

/////////////////////////////////////////////////////////////////////
// Stench
/////////////////////////////////////////////////////////////////////
IF
  Range(NearestEnemyOf(Myself),8)
  !GlobalTimerNotExpired("Stench","LOCALS")
THEN
  RESPONSE #100
    SetGlobalTimer("Stench","LOCALS",6)
    ReallyForceSpellRES("AC#HEZR",Myself)  // Stench
    Continue()
END

/////////////////////////////////////////////////////////////////////
// Blur
/////////////////////////////////////////////////////////////////////
IF
  OR(2)
    !GlobalTimerNotExpired("MO_SpellCastTimer","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  !AreaCheck("ACPP71")
  !TimeOfDay(NIGHT)
  Global("Blur","LOCALS",0)
  HPPercentLT(Myself,50)
THEN
  RESPONSE #100
    SetGlobal("Blur","LOCALS",1)
    SetGlobalTimer("MO_SpellCastTimer","LOCALS",6)
    SetInterrupt(FALSE)
    ForceSpell(Myself,WIZARD_BLUR)  // SPWI201.SPL (Blur)
    SetInterrupt(TRUE)
END

/////////////////////////////////////////////////////////////////////
// Protection From Normal Missiles
/////////////////////////////////////////////////////////////////////
IF
  OR(2)
    !GlobalTimerNotExpired("MO_SpellCastTimer","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  !AreaCheck("ACPP71")
  !TimeOfDay(NIGHT)
  See(NearestEnemyOf(Myself))
  Global("Missile","LOCALS",0)
THEN
  RESPONSE #100
    SetGlobal("Missile","LOCALS",1)
    SetGlobalTimer("MO_SpellCastTimer","LOCALS",6)
    SetInterrupt(FALSE)
    ForceSpellRES("AC#HEZP",Myself)  // Protection From Normal Missiles
    SetInterrupt(TRUE)
END

/////////////////////////////////////////////////////////////////////
// Globe of Darkness
/////////////////////////////////////////////////////////////////////
IF
  OR(2)
    !GlobalTimerNotExpired("MO_SpellCastTimer","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  !GlobalTimerNotExpired("Darkness_Timer","LOCALS")
  GlobalLT("Darkness","LOCALS",2)
  !AreaCheck("ACPP71")
  !TimeOfDay(NIGHT)
  Range(SixthNearestEnemyOf(Myself),12)
  !StateCheck(SixthNearestEnemyOf(Myself),STATE_BLIND)
  !CheckSpellState(SixthNearestEnemyOf(Myself),SI_ENCHANTMENT)
  !StateCheck(SixthNearestEnemyOf(Myself),STATE_NOT_TARGETABLE)
  !StateCheck(SixthNearestEnemyOf(Myself),STATE_IMPROVEDINVISIBILITY)
  !CheckStatGT(SixthNearestEnemyOf(Myself),0,SANCTUARY)
  CheckStatLT(SixthNearestEnemyOf(Myself),1,WIZARD_SPELL_DEFLECTION)
  CheckStatLT(SixthNearestEnemyOf(Myself),1,WIZARD_SPELL_TURNING)
  !CheckStat(SixthNearestEnemyOf(Myself),1,WIZARD_SPELL_TRAP)
  !CheckStat(SixthNearestEnemyOf(Myself),1,CLERIC_SHIELD_OF_THE_ARCHONS)
  CheckStatLT(SixthNearestEnemyOf(Myself),80,RESISTMAGIC)
  See(SixthNearestEnemyOf(Myself))
  False()
THEN
  RESPONSE #100
    NoAction()
END

