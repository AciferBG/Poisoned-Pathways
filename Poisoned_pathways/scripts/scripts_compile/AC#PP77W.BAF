IF
    See(NearestEnemyOf(Myself))
    Global("firstUse","LOCALS",0)
THEN
    RESPONSE #100
        ReallyForceSpell(NearestEnemyOf(Myself),BANSHEE_WAIL)  // SPIN681.SPL (Wail of the Banshee)
        SetGlobal("firstUse","LOCALS",1)
END

IF
    See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
        AttackReevaluate(NearestEnemyOf(Myself),5)
END

