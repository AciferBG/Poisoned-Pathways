IF
    Global("JournalUpdate","ACPP71",0)
THEN
    RESPONSE #100
        AddJournalEntry(@12008,QUEST)
        SetGlobal("JournalUpdate","ACPP71",1)
END

IF
    !GlobalTimerNotExpired("AntimagicTimer","ACPP71")
THEN
    RESPONSE #100
        ApplySpellRES("AC#PPDM",Player1)  // No such index
        SetGlobalTimer("AntimagicTimer","ACPP71",ONE_ROUND)
END

