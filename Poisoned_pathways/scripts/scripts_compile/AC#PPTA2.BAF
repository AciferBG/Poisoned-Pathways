/////////////////////////////////////////////////////////////////////
// Spell: Dolorous Decay
/////////////////////////////////////////////////////////////////////
IF
  OR(2)
    !GlobalTimerNotExpired("MO_SpellCastTimer","LOCALS")
    CheckStatGT(Myself,0,AURACLEANSING)
  HaveSpell(CLERIC_DOLOROUS_DECAY)  // SPPR610.SPL (Dolorous Decay)
  !General(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),UNDEAD)
  !General(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),PLANT)
  !Race(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),DEMONIC)
  !Race(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),TROLL)
  !Race(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),SLIME)
  CheckStatLT(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),50,RESISTPOISON)
  !HasItem("AMUL22",SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]))  // ~Periapt of Proof Against Poison~
  !HasItem("RING46",SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]))  // ~Ring of Anti-Venom~
  CheckStatGT(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),-2,SAVEVSDEATH)
  !StateCheck(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),STATE_POISONED)
  !StateCheck(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),STATE_NOT_TARGETABLE)
  !CheckSpellState(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),SI_TRANSMUTATION)
  !StateCheck(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),STATE_IMPROVEDINVISIBILITY)
  CheckStatLT(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),1,WIZARD_SPELL_DEFLECTION)
  CheckStatLT(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),1,WIZARD_SPELL_TURNING)
  !CheckStat(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),1,WIZARD_SPELL_TRAP)
  !CheckStat(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),1,CLERIC_SHIELD_OF_THE_ARCHONS)
  CheckStatLT(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]),50,MAGICDAMAGERESISTANCE)
  !HasItem("MORSWORD",SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]))  // Mordenkainen's Sword
  See(SixthNearestEnemyOfType([GOODCUTOFF.HUMANOID]))
  False()
THEN
  RESPONSE #100
    NoAction()
END

