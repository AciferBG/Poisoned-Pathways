IF
    RandomNum(5,5)
    See(NearestEnemyOf(Myself))
    !TimeOfDay(NIGHT)
    Global("AC#PPWispAttackWithSpells","LOCALS",0)
THEN
    RESPONSE #50
        SetGlobal("AC#PPWispAttackWithSpells","LOCALS",1)
        ReallyForceSpell(NearestEnemyOf(Myself),WIZARD_EMOTION_HOPELESSNESS)  // SPWI411.SPL (Emotion: Hopelessness)
    RESPONSE #100
        Continue()
END

IF
    TookDamage()
    See(NearestEnemyOf(Myself))
    RandomNum(10,1)
    GlobalLT("WispInvisible","LOCALS",3)
THEN
    RESPONSE #100
        ForceSpell(Myself,WIZARD_INVISIBILITY)  // SPWI206.SPL (Invisibility)
        IncrementGlobal("WispInvisible","LOCALS",1)
END

IF
    See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
        AttackReevaluate(NearestEnemyOf(Myself),10)
END

