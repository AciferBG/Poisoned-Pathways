IF
    RandomNum(5,4)
    See(NearestEnemyOf(Myself))
    !TimeOfDay(NIGHT)
    Global("AC#PPWispAttackWithSpells","LOCALS",0)
THEN
    RESPONSE #50
        SetGlobal("AC#PPWispAttackWithSpells","LOCALS",1)
        ReallyForceSpell(NearestEnemyOf(Myself),WIZARD_LIGHTNING_BOLT)  // SPWI308.SPL (Lightning Bolt)
    RESPONSE #100
        Continue()
