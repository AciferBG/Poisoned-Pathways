IF
   OR(2)
    IsOverMe([PC])
    Entered([ANYONE])
   Global("DeadMagicInfo","ACPP70",0)
THEN
    RESPONSE #100
        DisplayStringPoint([961.2468],@2004)
        //DisplayStringHead(Myself,@2004)   
        SetGlobal("DeadMagicInfo","ACPP70",1)
        SetGlobal("AC#PP_GoMythal","GLOBAL",1)
END

