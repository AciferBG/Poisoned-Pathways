IF
    Global("EldathBless","ACPP06",1)
THEN
    RESPONSE #100
        CreateVisualEffect("SPDHRMNY",[581.333])
        SetGlobal("EldathBless","ACPP06",0)
END

IF
    GlobalGT("AC#PPTradeItems","GLOBAL",0)
    Global("EldathWeaponJournal","ACPP06",0)
THEN
    RESPONSE #100
    AddJournalEntry(@13111,QUEST_DONE)        
        SetGlobal("EldathWeaponJournal","ACPP06",1)
END

