IF
    See(NearestEnemyOf(Myself))
    Global("RakCloud","GLOBAL",0)
THEN
    RESPONSE #30
        ForceSpell(NearestEnemyOf(Myself),WIZARD_CLOUDKILL)  // SPWI502.SPL (Cloudkill)
        SetGlobal("RakCloud","GLOBAL",1)
    RESPONSE #30
        ForceSpell(NearestEnemyOf(Myself),WIZARD_DEATH_FOG)  // SPWI614.SPL (Death Fog)
        SetGlobal("RakCloud","GLOBAL",1)
    RESPONSE #40
        Continue()
END

IF
    See(NearestEnemyOf(Myself))
    Global("RakshasaBolt","LOCALS",0)
THEN
    RESPONSE #30
        Spell(NearestEnemyOf(Myself),WIZARD_LIGHTNING_BOLT)  // SPWI308.SPL (Lightning Bolt)
        SetGlobal("RakshasaBolt","LOCALS",1)
END

IF
    See([GOODCUTOFF])
    Global("RakshasaBall","LOCALS",0)
THEN
    RESPONSE #30
        Spell(NearestEnemyOf(Myself),WIZARD_FIREBALL)  // SPWI304.SPL (Fireball)
        SetGlobal("RakshasaBall","LOCALS",1)
END

IF
    See(NearestEnemyOf(Myself))
    HaveSpell(WIZARD_FIREBALL)  // SPWI304.SPL (Fireball)
THEN
    RESPONSE #100
        Spell(NearestEnemyOf(Myself),WIZARD_FIREBALL)  // SPWI304.SPL (Fireball)
END

