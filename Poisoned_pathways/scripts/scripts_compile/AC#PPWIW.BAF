IF
    See(NearestEnemyOf(Myself))
THEN
    RESPONSE #100
        ReallyForceSpellRES("AC#PPWW",NearestEnemyOf(Myself))  // Prismatic Spray
    RESPONSE #100
        AttackReevaluate(NearestEnemyOf(Myself),6)
END

