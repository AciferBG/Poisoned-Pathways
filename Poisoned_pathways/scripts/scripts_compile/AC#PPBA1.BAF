IF
    NumberOfTimesTalkedTo(0)
    Allegiance(Myself,NEUTRAL)
THEN
    RESPONSE #100
        ClearAllActions()
        StartCutSceneMode()
        CreateVisualEffectObject("SPFLESHS",Myself)
        SmallWait(15)
        DisplayStringHead(Myself,@2007)
        SmallWait(15)
        StartDialogueNoSet([PC])
END
