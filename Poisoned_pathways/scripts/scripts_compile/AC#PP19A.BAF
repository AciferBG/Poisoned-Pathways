IF
    Global("AC#PP_Killed_Wyrd_2_time","GLOBAL",1)
THEN
    RESPONSE #100
        Wait(1)
        SetGlobal("AC#PP_Killed_Wyrd_2_time","GLOBAL",2)
        Kill(Myself)
END

IF
    Global("AC#PP_Killed_Wyrd_2_time","GLOBAL",0)
THEN
    RESPONSE #100
        Wait(1)
        CreateVisualEffectObject("SPFLESHS",Myself)
        SmallWait(15)
        ChangeAnimation("AC#PPWY9")  // The Undying
END

