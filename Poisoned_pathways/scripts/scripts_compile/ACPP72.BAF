IF
   OnCreation()
THEN
    RESPONSE #100
        ApplySpellRES("AC#PPRM",Player1)  // No such index
        Continue()
END

IF
    Global("AC#PPFinalBossPrepare","GLOBAL",0)
    Global("AC#PPFinalBossDialog","ACPP72",1)
THEN
    RESPONSE #100
        SpawnPtDeactivate("Spawn_undead01")
        SpawnPtDeactivate("Spawn_undead02")
        StartCutScene("AC#PPCT6")
END

IF
    Global("AC#PP_MythUnnohyr","GLOBAL",10)
    Global("Ch6Changes","ACPP72",0)
THEN
    RESPONSE #100
        Unlock("DOOR01")
        OpenDoor("DOOR01")
        SpawnPtActivate("Spawn_undead01")
        SpawnPtActivate("Spawn_undead02")
        SetGlobal("Ch6Changes","ACPP72",1)
END

IF
    PartyHasItem("AC#PPANT")
    Global("JournalUpdateFinal","ACPP72",0)
THEN
    RESPONSE #100
        AddJournalEntry(@12110,QUEST)
        SetGlobal("JournalUpdateFinal","ACPP72",1)
END


IF
   OR(2)
        Difficulty(HARDEST)
        LevelPartyGT(14)
    GlobalGT("AC#PPFinalBossPrepare","GLOBAL",2)
    Global("CreatePoisonWeird","ACPP72",0)
THEN
    RESPONSE #100
        CreateCreatureImpassable("AC#PPPOW",[545.527],N)  // Poison Weird
        CreateCreatureImpassable("AC#PPPOW",[931.501],N)  // Poison Weird
        CreateCreatureImpassable("AC#PPPOW",[631.782],NW)  // Poison Weird
        CreateCreatureImpassable("AC#PPPOW",[1006.674],NE)  // Poison Weird
        SetGlobal("CreatePoisonWeird","ACPP72",1)
END

IF
    LevelPartyGT(12)
    GlobalGT("AC#PPFinalBossPrepare","GLOBAL",2)
    Global("CreatePoisonWeird","ACPP72",0)
THEN
    RESPONSE #100
        CreateCreatureImpassable("AC#PPPOW",[545.527],N)  // Poison Weird
        CreateCreatureImpassable("AC#PPPOW",[931.501],N)  // Poison Weird
        CreateCreatureImpassable("AC#PPPOW",[631.782],NW)  // Poison Weird
        SetGlobal("CreatePoisonWeird","ACPP72",1)
END

