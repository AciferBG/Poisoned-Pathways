IF
    GlobalGT("AC#PPFinalBossPrepare","GLOBAL",2)
    Global("AdditionalSpawns","ACPP72",0)
    DifficultyGT(EASY)
THEN
    RESPONSE #100
        CreateCreature("AC#PPGH1",[427.814],S)  // Ghoul
        CreateCreature("AC#PPGH1",[999.894],S)  // Ghoul
        CreateCreature("AC#PPGH1",[1192.568],S)  // Ghoul
        CreateCreature("AC#PPSCR",[331.776],S)  // Scorpion
        CreateCreature("AC#PPSCR",[1213.683],S)  // Scorpion
        CreateCreature("AC#PPSN1",[747.942],S)  // Viper
        SetGlobal("AdditionalSpawns","ACPP72",1)
END

IF
    Global("AC#PPFinalBossPrepare","GLOBAL",2)
    Difficulty(EASIEST)
THEN
    RESPONSE #100
        ActionOverride("AC#PPTA2",Enemy())
        StartCombatCounter()
        //ClearAllActions()
        //StartCutSceneMode()
        //ClearAllActions()
        ScreenShake([20.20],3)
        CreateVisualEffectObject("SPFLESHS","AC#PPTA2")  // Delgorth
        CreateVisualEffect("SPANISUM",[350.500])
        CreateVisualEffect("SPANISUM",[520.370])
        CreateVisualEffect("SPANISUM",[950.330])
        CreateVisualEffect("SPANISUM",[1100.420])
        CreateVisualEffect("SPANISUM",[750.200])
        Wait(2)
        CreateCreature("AC#PPGH1",[350.500],S)  // Ghoul
        CreateCreature("AC#PPGH1",[520.370],S)  // Ghoul
        SetGlobal("AC#PPFinalBossPrepare","GLOBAL",3)
        //ActionOverride("AC#PPTA2",Enemy())
        //EndCutSceneMode()
END

