IF
    Die()
THEN
    RESPONSE #100
        CreateVisualEffectObject("SPUNHOLY",Myself)
        DestroySelf()
END

IF
    Dead("AC#PPWYR")  // The Undying
THEN
    RESPONSE #100
        DestroySelf()
END

IF
    RandomNum(5,1)
    See(NearestEnemyOf(Myself))
    Global("AC#PPSoulAttackWithSpells","LOCALS",0)
THEN
    RESPONSE #100
        DisplayStringHead(Myself,109810)  // Blood... All I can see is blood!
        SetGlobal("AC#PPSoulAttackWithSpells","LOCALS",1)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_GREATER_MALISON)  // SPWI412.SPL (Greater Malison)
END

IF
    RandomNum(5,2)
    See(NearestEnemyOf(Myself))
    Global("AC#PPSoulAttackWithSpells","LOCALS",0)
THEN
    RESPONSE #100
        DisplayStringHead(Myself,109811)  // Free me! Please!
        SetGlobal("AC#PPSoulAttackWithSpells","LOCALS",1)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_LARLOCH_MINOR_DRAIN)  // SPWI119.SPL (Larloch's Minor Drain)
END

