IF
    RandomNum(5,5)
    See(NearestEnemyOf(Myself))
    Global("AC#PPSoulAttackWithSpells","LOCALS",0)
THEN
    RESPONSE #100
        SetGlobal("AC#PPSoulAttackWithSpells","LOCALS",1)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_FIRE_SHIELD_RED)  // SPWI418.SPL (Fire Shield (Red))
