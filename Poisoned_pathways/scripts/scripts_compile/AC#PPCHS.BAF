IF
    See([PC])
    Global("Silence","LOCALS",0)
THEN
    RESPONSE #100
        ForceSpell([PC],TANARI_SILENCE)  // SPIN998.SPL (Silence, 15' Radius)
        SetGlobal("Silence","LOCALS",1)
