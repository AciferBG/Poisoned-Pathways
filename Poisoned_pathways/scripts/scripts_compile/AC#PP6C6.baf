IF
    True()
THEN
    RESPONSE #100
        CutSceneId("AC#PPWYR")  // The Undying
        MoveViewObject("AC#PPSD2",INSTANT)  // No such index
        CreateCreatureObjectOffset("CUTSPY","AC#PPSD2",[3.3])  // No such index
