    AreaCheck("ACPP77")
    See(NearestEnemyOf(Myself))
    Global("AC#PPChapter6Quest","GLOBAL",20)
    Global("AC#PP70FightSpells_F","LOCALS",3)
    GlobalTimerExpired("AC#PP70FightSpellsTime_F","LOCALS")
THEN
    RESPONSE #100
        ApplySpell(Myself,WIZARD_CARRION)  // SPWI623.SPL (Carrion Summons)
        SetGlobal("AC#PP70FightSpells_F","LOCALS",4)
        SetGlobalTimer("AC#PP70FightSpellsTime_F","LOCALS",9)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_FINGER_OF_DEATH)  // SPWI713.SPL (Finger of Death)
