IF
    Global("AC#PPChapter6Quest","GLOBAL",20)
    HPLT(Myself,3)
THEN
    RESPONSE #100
        SetGlobal("AC#PPChapter6Quest","GLOBAL",21)
END

IF
    Global("AC#PPChapter6Quest","GLOBAL",21)
THEN
    RESPONSE #100
        StartDialogueNoSet(Player1)
END

IF
    OR(2)
        See([PC])
        Range([PC],25)
    Global("AC#PPChapter6Quest","GLOBAL",1)
THEN
    RESPONSE #100
        SetGlobal("AC#PPChapter6Quest","GLOBAL",2)
        StartDialogueNoSet(Player1)
END

IF
    Global("AC#PPChapter6Quest","GLOBAL",3)
    HPLT(Myself,10)
THEN
    RESPONSE #100
        SetGlobal("AC#PPChapter6Quest","GLOBAL",4)
END

IF
    Global("AC#PPChapter6Quest","GLOBAL",4)
THEN
    RESPONSE #100
        StartDialogueNoSet(Player1)
END

IF
    AreaCheck("ACPP77")
    See(NearestEnemyOf(Myself))
    Global("AC#PPChapter6Quest","GLOBAL",3)
    Global("AC#PP70FightSpells","LOCALS",0)
THEN
    RESPONSE #100
        ApplySpellRES("AC#PP43",Myself)  // Necrotic Shield
        SetGlobal("AC#PP70FightSpells","LOCALS",1)
        SetGlobalTimer("AC#PP70FightSpellsTime","LOCALS",9)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_FINGER_OF_DEATH)  // SPWI713.SPL (Finger of Death)
END

IF
    AreaCheck("ACPP77")
    See(NearestEnemyOf(Myself))
    Global("AC#PPChapter6Quest","GLOBAL",3)
    Global("AC#PP70FightSpells","LOCALS",1)
    GlobalTimerExpired("AC#PP70FightSpellsTime","LOCALS")
THEN
    RESPONSE #100
        ApplySpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (Mirror Image)
        ApplySpell(Myself,WIZARD_PROTECTION_FROM_NORMAL_WEAPONS)  // SPWI511.SPL (Protection From Normal Weapons)
        SetGlobal("AC#PP70FightSpells","LOCALS",2)
        SetGlobalTimer("AC#PP70FightSpellsTime","LOCALS",9)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_ABI_DALZIMS_HORRID_WILTING)  // SPWI812.SPL (Abi-Dalzim's Horrid Wilting)
END

IF
    AreaCheck("ACPP77")
    See(NearestEnemyOf(Myself))
    Global("AC#PPChapter6Quest","GLOBAL",3)
    Global("AC#PP70FightSpells","LOCALS",2)
    GlobalTimerExpired("AC#PP70FightSpellsTime","LOCALS")
THEN
    RESPONSE #100
        ApplySpell(Myself,WIZARD_WYVERN_CALL)  // SPWI619.SPL (Wyvern Call)
        SetGlobal("AC#PP70FightSpells","LOCALS",3)
        ForceSpell(NearestEnemyOf(Myself),WIZARD_CHAIN_LIGHTNING)  // SPWI615.SPL (Chain Lightning)
END

IF
    Global("AC#PPChapter6Quest","GLOBAL",18)
THEN
    RESPONSE #100
        StartDialogueNoSet(Player1)
END

