        SetGlobal("AC#PP70FightSpells_F","LOCALS",5)
        SetGlobalTimer("AC#PP70FightSpellsTime_F","LOCALS",9)
        ForceSpell(Player1,WIZARD_MAGIC_MISSILE)  // SPWI112.SPL (Magic Missile)
        ForceSpell(Player2,WIZARD_MAGIC_MISSILE)  // SPWI112.SPL (Magic Missile)
        ForceSpell(Player3,WIZARD_MAGIC_MISSILE)  // SPWI112.SPL (Magic Missile)
        ForceSpell(Player4,WIZARD_MAGIC_MISSILE)  // SPWI112.SPL (Magic Missile)
        ForceSpell(Player5,WIZARD_MAGIC_MISSILE)  // SPWI112.SPL (Magic Missile)
