    Global("AC#PPChapter6Quest","GLOBAL",19)
THEN
    RESPONSE #100
        StartDialogueNoSet(Player1)
END

IF
    AreaCheck("ACPP77")
    See(NearestEnemyOf(Myself))
    Global("AC#PPChapter6Quest","GLOBAL",20)
    Global("AC#PP70FightSpells_F","LOCALS",0)
THEN
    RESPONSE #100
        ApplySpell(Myself,WIZARD_FIRE_SHIELD_BLUE)  // SPWI403.SPL (Fire Shield (Blue))
        ApplySpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (Mirror Image)
        ApplySpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (Protection From Magical Weapons)
        SetGlobal("AC#PP70FightSpells_F","LOCALS",1)
        SetGlobalTimer("AC#PP70FightSpellsTime_F","LOCALS",9)
END

