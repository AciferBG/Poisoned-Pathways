    See(NearestEnemyOf(Myself))
    Global("AC#PPChapter6Quest","GLOBAL",20)
    Global("AC#PP70FightSpells_F","LOCALS",4)
    GlobalTimerExpired("AC#PP70FightSpellsTime_F","LOCALS")
